    QT_TRANSLATE_NOOP("Quotes", u8"Viagem Ao Centro da Terra de Jules Verne foi publicado em 1864. Na época, os conceitos sobre o núcleo da terra ainda eram um terrítório pouco explorado pela ciência."),
